---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import FloatingCTA from "../../components/FloatingCTA.astro";
import CTASection from "../../components/CTASection.astro";
import { areas, groupAreasByRegion, regionLabels, areasToItemListJsonLd, type AreaRegion } from "../../data/areas";
import { areaPath, homePath, basePath, assetPath } from "../../lib/site";
import { company } from "../../data/company";

const grouped = groupAreasByRegion();
const regionOrder: AreaRegion[] = ["nagoya", "owari", "chita", "mikawa", "mie"];

const siteUrl = Astro.site ?? new URL(Astro.url.origin);
const homeUrl = new URL(homePath, siteUrl).toString();
const itemListJsonLd = areasToItemListJsonLd(siteUrl, basePath);
const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "徳丸商会トップ", "item": homeUrl },
    { "@type": "ListItem", "position": 2, "name": "対応エリア一覧", "item": new URL(`${basePath}area/`, siteUrl).toString() },
  ],
};

const bgNagoya = assetPath("images/bg-nagoya.webp");

const regionIcons: Record<AreaRegion, string> = {
  nagoya: "M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z M12 7a3 3 0 1 0 0 6 3 3 0 0 0 0-6z",
  owari: "M3 12h18 M12 3v18 M5 5l14 14 M5 19L19 5",
  chita: "M12 22s-7-7-7-12a7 7 0 0 1 14 0c0 5-7 12-7 12z",
  mikawa: "M2 22h20 M5 18l3-9 3 6 4-12 5 15",
  mie: "M3 6l9-4 9 4 M3 18l9 4 9-4 M3 12l9-4 9 4",
};
---
<Layout
  title="対応エリア一覧（全27エリア）｜名古屋の出張買取・不用品回収 徳丸商会"
  description="徳丸商会が出張買取・不用品回収に対応する名古屋市16区＋近郊主要11市の合計27エリアを地域別にご紹介。お住まいのエリアから最短訪問可能な詳細ページへどうぞ。受付9:00–21:00年中無休。"
>
  <Header />

  <main>
    <!-- Breadcrumb -->
    <nav aria-label="パンくず" class="bg-bg-cream border-b border-border text-xs text-text-lighter">
      <ol class="max-w-5xl mx-auto px-5 py-2 flex items-center gap-2 overflow-x-auto whitespace-nowrap">
        <li><a href={homePath} class="hover:text-terra transition-colors">トップ</a></li>
        <li class="text-text-lighter/60">/</li>
        <li class="text-text font-bold">対応エリア</li>
      </ol>
    </nav>

    <!-- Hero -->
    <section class="relative bg-dark text-white py-14 md:py-24 overflow-hidden">
      <img src={bgNagoya} alt="" class="absolute inset-0 w-full h-full object-cover" loading="eager" decoding="async" width="1200" height="800" />
      <!-- 中央テキスト可読性のためラジアル風（中濃→端薄） -->
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,rgba(44,36,32,0.85)_0%,rgba(44,36,32,0.65)_50%,rgba(44,36,32,0.35)_100%)]"></div>
      <div class="absolute -top-32 -right-32 w-96 h-96 bg-terra/40 rounded-full blur-3xl"></div>
      <div class="absolute -bottom-32 -left-32 w-96 h-96 bg-amber/25 rounded-full blur-3xl"></div>

      <div class="relative max-w-5xl mx-auto px-5 text-center">
        <div class="reveal reveal-up flex flex-wrap justify-center items-center gap-2 mb-5">
          <span class="inline-flex items-center gap-2 bg-terra/15 border border-terra/30 text-terra-light rounded-full px-3 py-1.5 text-[11px] md:text-sm font-bold">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            愛知＋三重 27エリア対応
          </span>
          <span class="inline-flex items-center gap-1.5 bg-gradient-to-r from-terra/25 to-amber/25 border border-amber/40 text-amber-light rounded-full px-3 py-1.5 text-[11px] md:text-sm font-bold badge-pulse">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3 md:w-3.5 md:h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>
            <span>キャンペーン中</span>
            <span class="text-white/40">／</span>
            <span class="text-gradient font-black">買取金額10%UP</span>
          </span>
        </div>

        <h1 class="reveal reveal-up font-black mb-5 leading-tight">
          <span class="block text-base md:text-2xl text-white/70 font-bold mb-2">徳丸商会の</span>
          <span class="block text-3xl md:text-6xl text-gradient">対応エリア一覧</span>
        </h1>
        <p class="reveal reveal-up text-white/85 text-sm md:text-lg leading-relaxed max-w-2xl mx-auto mb-8">
          名古屋市全16区＋愛知県近郊・三重県北部の主要11市の合計<strong class="text-terra-light">27エリア</strong>で出張買取・不用品回収・遺品整理に対応。お住まいのエリア詳細ページから最短訪問可能日時をご確認いただけます。
        </p>

        <!-- 統計カード -->
        <div class="reveal reveal-up grid grid-cols-3 gap-3 md:gap-5 max-w-3xl mx-auto mb-8">
          <div class="bg-white/5 backdrop-blur-sm border border-white/15 rounded-xl p-3 md:p-5">
            <p class="text-2xl md:text-4xl font-black text-gradient leading-none mb-1">27</p>
            <p class="text-[11px] md:text-sm text-white/85 font-bold">対応エリア</p>
            <p class="text-[10px] md:text-xs text-white/45 mt-0.5">愛知＋三重北部</p>
          </div>
          <div class="bg-white/5 backdrop-blur-sm border border-white/15 rounded-xl p-3 md:p-5">
            <p class="text-2xl md:text-4xl font-black text-gradient leading-none mb-1">16<span class="text-base md:text-2xl">区</span></p>
            <p class="text-[11px] md:text-sm text-white/85 font-bold">名古屋市全域</p>
            <p class="text-[10px] md:text-xs text-white/45 mt-0.5">全区対応済</p>
          </div>
          <div class="bg-line/15 backdrop-blur-sm border border-line/40 rounded-xl p-3 md:p-5 relative">
            <span class="absolute top-1 right-1 bg-line text-white text-[8px] md:text-[9px] font-black px-1.5 py-0.5 rounded-full shadow">NEW</span>
            <p class="text-2xl md:text-4xl font-black leading-none mb-1 text-line">24<span class="text-base md:text-2xl">h</span></p>
            <p class="text-[11px] md:text-sm text-white/95 font-bold">LINE受付</p>
            <p class="text-[10px] md:text-xs text-white/55 mt-0.5">時間外は翌朝対応</p>
          </div>
        </div>

        <!-- CTA (順序: 電話→LINE Header基準) -->
        <div class="reveal reveal-up flex flex-col sm:flex-row justify-center gap-3">
          <a href="tel:052-990-3968" class="cta-glow inline-flex items-center justify-center gap-2 bg-terra hover:bg-terra-light text-white font-bold text-sm md:text-base px-6 py-3 rounded-xl shadow-lg transition-transform hover:scale-105">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            <span>電話で相談する</span>
          </a>
          <a href="https://lin.ee/j4wK9IM" target="_blank" rel="noopener noreferrer" class="cta-glow-line inline-flex items-center justify-center gap-2 bg-line text-white font-bold text-sm md:text-base px-6 py-3 rounded-xl shadow-lg transition-transform hover:scale-105">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .63.283.63.63 0 .344-.281.629-.63.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63h2.386c.346 0 .627.285.627.63 0 .349-.281.63-.63.63H17.61v1.125h1.755zm-3.855 3.016c0 .27-.174.51-.432.596a.629.629 0 0 1-.51-.25l-2.443-3.317v2.94c0 .344-.279.629-.631.629-.346 0-.626-.285-.626-.629V8.108c0-.27.173-.51.43-.595a.63.63 0 0 1 .495.254l2.462 3.33V8.108c0-.345.282-.63.63-.63.345 0 .63.285.63.63v4.771zm-5.741 0c0 .344-.282.629-.631.629-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63.346 0 .628.285.628.63v4.771zm-2.466.629H4.917c-.345 0-.63-.285-.63-.629V8.108c0-.345.285-.63.63-.63.348 0 .63.285.63.63v4.141h1.756c.348 0 .629.283.629.63 0 .344-.282.629-.629.629M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.078 9.436-6.975C23.176 14.393 24 12.458 24 10.314"/></svg>
            <span>LINEで無料査定</span>
          </a>
        </div>
      </div>
    </section>

    <!-- Region tabs (sticky) -->
    <nav class="sticky top-14 z-40 bg-bg-warm/95 backdrop-blur-sm border-b border-border shadow-sm">
      <div class="max-w-5xl mx-auto px-5">
        <ul class="flex gap-2 overflow-x-auto py-3 text-xs md:text-sm font-bold scrollbar-hide">
          {regionOrder.map((r) => (
            <li class="flex-shrink-0">
              <a href={`#region-${r}`} class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-white border border-border text-text hover:bg-terra hover:text-white hover:border-terra transition-colors">
                {regionLabels[r]}
                <span class="text-text-lighter text-[10px] md:text-xs ml-0.5">{grouped[r].length}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </nav>

    <!-- Areas by region -->
    <section class="py-14 md:py-20 bg-bg relative overflow-hidden">
      <div class="absolute inset-0 dots-pattern opacity-30"></div>
      <div class="relative max-w-5xl mx-auto px-5 space-y-12 md:space-y-16">
        {regionOrder.map((region) => (
          <div id={`region-${region}`} class="scroll-mt-32 reveal reveal-up">
            <div class="flex items-baseline gap-3 mb-5 md:mb-7 pb-3 border-b-2 border-border">
              <div class="flex items-center gap-3">
                <span class="inline-flex items-center justify-center w-10 h-10 md:w-12 md:h-12 rounded-xl bg-gradient-to-br from-terra to-amber shadow-md">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 md:w-6 md:h-6 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d={regionIcons[region]}/>
                  </svg>
                </span>
                <div>
                  <h2 class="text-xl md:text-3xl font-black text-text">{regionLabels[region]}</h2>
                  <p class="text-text-lighter text-xs md:text-sm">{grouped[region].length}エリア対応</p>
                </div>
              </div>
            </div>
            <ul class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3 md:gap-4 stagger-children">
              {grouped[region].map((a) => (
                <li class="reveal reveal-up">
                  <a href={areaPath(a.slug)} class="group flex flex-col h-full bg-white rounded-2xl p-4 md:p-5 border border-border card-hover hover:border-terra transition-colors relative overflow-hidden">
                    <div class="absolute top-0 inset-x-0 h-1 bg-gradient-to-r from-terra to-amber opacity-0 group-hover:opacity-100 transition-opacity"></div>
                    <span class="font-bold text-text group-hover:text-terra text-base md:text-lg mb-1 transition-colors">{a.name}</span>
                    <span class="text-text-lighter text-[11px] md:text-xs leading-relaxed flex-1">{a.shortDescription}</span>
                    <span class="mt-3 inline-flex items-center gap-1 text-terra text-xs font-bold opacity-0 group-hover:opacity-100 transition-opacity">
                      詳細を見る
                      <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg>
                    </span>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </section>

    <!-- Coverage notice -->
    <section class="py-12 md:py-16 bg-bg-cream">
      <div class="max-w-3xl mx-auto px-5 text-center reveal reveal-up">
        <p class="text-terra text-xs font-bold tracking-widest uppercase mb-2">Outside Coverage</p>
        <h2 class="text-lg md:text-2xl font-black text-text mb-3">該当エリア外でもまずはご相談ください</h2>
        <p class="text-text-light text-sm md:text-base leading-relaxed">
          上記27エリア以外でも、愛知県内・三重県北部の一部地域に対応できる場合があります。お電話・LINEで対応可否を即日ご回答いたします。古物商許可 {company.permitNumber}（{company.permitAuthority}届出）。
        </p>
      </div>
    </section>

    <CTASection variant="bottom" />
  </main>

  <Footer />
  <FloatingCTA />

  <!-- reveal observer (is:inline でAstroバンドラをスキップし即時実行) -->
  <script is:inline>
    function initReveal() {
      var els = document.querySelectorAll('.reveal');
      if (!els.length) return;
      var observer = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.05, rootMargin: '0px 0px -20px 0px' });
      els.forEach(function(el) { observer.observe(el); });
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initReveal);
    } else {
      initReveal();
    }
    window.addEventListener('load', initReveal);
  </script>

  <script type="application/ld+json" set:html={JSON.stringify(itemListJsonLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />
</Layout>
