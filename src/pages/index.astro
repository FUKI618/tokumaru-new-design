      <div class="absolute inset-0 bg-[linear-gradient(90deg,rgba(20,12,6,.5),transparent_28%,transparent_72%,rgba(20,12,6,.5))]"></div><div class="absolute inset-0 bg-gradient-to-b from-dark/45 from-0% via-dark/10 via-38% to-dark"></div>
