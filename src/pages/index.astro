const cases = [
  {
    before: case1Before, after: case1After,
    title: "遺品整理（和室6畳＋押入れ）",
    who: "名古屋市千種区 K.S様 60代女性",
    price: "実質負担 42,000円",
    priceDetail: "買取額 98,000円で整理費用を大幅相殺",
    desc: "亡くなったお母様の遺品整理。着物30点・箪笥・掛軸・茶道具を仕分け。着物と掛軸に値がつき、整理費用の大半を買取額で相殺。立会い不要で対応。",
  },
  {
    before: case2Before, after: case2After,
    title: "不用品回収（1K 洋室8㎡）",
    who: "名古屋市中区 T.M様 30代男性",
    price: "作業費 28,000円",
    priceDetail: "ソファ・TV・本棚など15点を一括回収",
    desc: "引越しに伴う不用品の一括処分。大型ソファ・液晶TV・本棚・段ボール多数を半日で搬出。買取可能な家電3点は費用から差し引き。",
  },
  {
    before: case3Before, after: case3After,
    title: "残置物撤去（キッチン+ダイニング）",
    who: "名古屋市緑区 Y.A様（管理会社）",
    price: "作業費 55,000円",
    priceDetail: "退去後の残置物を全撤去＋簡易清掃",
    desc: "賃貸退去後に残された冷蔵庫・食器棚・テーブル・大量のゴミ袋を撤去。管理会社からのご依頼で、原状回復の一環として簡易清掃まで対応。",
  },
];
const serviceCarry = assetPath("images/service-carry.webp");
const serviceEstate = assetPath("images/service-estate.webp");
const truckLoading = assetPath("images/truck-loading.webp");
const serviceZanchi = assetPath("images/service-zanchi.webp");
const bgTrust = assetPath("images/bg-trust.webp");
const bgPain = assetPath("images/bg-pain.webp");
const bgTeam = assetPath("images/bg-team.webp");
const bgCash = assetPath("images/bg-cash.webp");
const bgNagoya = assetPath("images/bg-nagoya.webp");
const bgHappy = assetPath("images/bg-happy.webp");

const results = [
  { name: "冷蔵庫", detail: "大型 500L以上", price: "39,000", img: assetPath("images/results/refrigerator.webp") },
  { name: "洗濯機", detail: "ドラム式", price: "24,500", img: assetPath("images/results/washing-machine.webp") },
  { name: "エアコン", detail: "取外し込み", price: "21,000", img: assetPath("images/results/aircon.webp") },
  { name: "テレビ", detail: "55インチ", price: "17,000", img: assetPath("images/results/tv.webp") },
];
const voices = [
  { text: "引越し前日に慌てて電話しましたが、2時間後には全部片付きました。思った以上の金額で買い取ってもらえました。", who: "名古屋市中区 T.S様", stars: 5, datePublished: "2026-03-12" },
  { text: "LINEで写真を送ったらすぐに概算が出て、翌日には訪問してもらえました。重い冷蔵庫の搬出も手際よかったです。", who: "名古屋市緑区 M.K様", stars: 5, datePublished: "2026-02-08" },
  { text: "他社で断られた古い家具も査定してくれて、値段がついたのは驚きでした。家族にも勧めています。", who: "あま市 Y.N様", stars: 5, datePublished: "2026-01-22" },
];
const areas = ["千種区","東区","北区","西区","中村区","中区","昭和区","瑞穂区","熱田区","中川区","港区","南区","守山区","緑区","名東区","天白区"];
const nearby = ["あま市","清須市","北名古屋市","津島市","愛西市","弥富市","東海市","大府市","刈谷市","豊明市","四日市市"];

// Review JSON-LD: 個別レビュー（aggregateRatingは景表法配慮で出さない）
const siteUrlForReview = Astro.site ?? new URL(Astro.url.origin);
const homeUrlForReview = new URL(homePath, siteUrlForReview).toString();
const reviewsJsonLd = voices.map((v, i) => ({
  "@context": "https://schema.org",
  "@type": "Review",
  "@id": `${homeUrlForReview}#review-${i + 1}`,
  "author": { "@type": "Person", "name": v.who },
  "reviewRating": {
    "@type": "Rating",
    "ratingValue": String(v.stars),
    "bestRating": "5",
    "worstRating": "1",
  },
  "reviewBody": v.text,
  "datePublished": v.datePublished,
  "itemReviewed": {
    "@type": "LocalBusiness",
    "@id": `${homeUrlForReview}#localbusiness`,
    "name": "徳丸商会",
  },
}));
---

<Layout
  title="名古屋の出張買取・不用品回収なら徳丸商会｜出張費0円・最短30分"
  description="名古屋市・近郊エリアの出張買取・不用品回収なら徳丸商会。家電・家具・ブランド品・貴金属をその場で現金買取。不用品回収・遺品整理・家じまい・残置物撤去も一括対応。出張費・査定費0円、最短30分で即日訪問。古物商許可業者。052-990-3968"
  includeTopSchemas={true}
>

<!-- ═══ HEADER ═══ -->
<!-- 上部帯: 電話番号+営業時間 (PCのみ) -->
<div class="hidden md:block fixed top-0 inset-x-0 z-50 bg-dark border-b border-white/5">
  <div class="max-w-6xl mx-auto px-5 h-8 flex items-center justify-end gap-6 text-[11px] text-white/50">
    <span>受付 9:00–21:00（年中無休）</span>
    <a href="tel:052-990-3968" class="flex items-center gap-1 text-white/70 hover:text-white transition-colors">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
      052-990-3968
    </a>
  </div>
</div>
<!-- メインヘッダー -->
<header class="fixed top-0 md:top-8 inset-x-0 z-50 bg-dark/95 backdrop-blur-md shadow-2xl border-b border-terra/15">
