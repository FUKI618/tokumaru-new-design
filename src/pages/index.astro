        <span class="text-white font-black text-xl md:text-2xl leading-tight tracking-tight">徳丸商会</span>
        <span class="text-white/60 text-[9px] md:text-xs font-bold leading-tight whitespace-nowrap">名古屋の出張買取・不用品回収</span>
      </div>
    </a>
    <nav class="hidden md:flex items-center gap-1">
      {[
        { label: "サービス", id: "service" },
        { label: "買取実績", id: "results" },
        { label: "対応エリア", id: "area" },
        { label: "FAQ", id: "faq" },
      ].map(item => (
        <a href={sectionPath(item.id)} class="text-white/60 hover:text-white hover:bg-white/5 text-sm font-bold px-4 py-2.5 rounded-lg transition-all">{item.label}</a>
      ))}
    </nav>
    <div class="flex items-center gap-2">
      <a href="tel:052-990-3968" class="flex items-center justify-center gap-1.5 bg-terra hover:bg-terra-light text-white font-bold text-[11px] md:text-sm px-3 md:px-5 py-2 md:py-3 rounded-lg md:rounded-xl transition-colors shadow-md whitespace-nowrap">
