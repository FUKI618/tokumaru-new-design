---
import Layout from "../layouts/Layout.astro";
import { assetPath, homePath, sectionPath, privacyPolicyPath } from "../lib/site";
import { faqs } from "../data/faq";
import { company } from "../data/company";

const logo = assetPath("logo.png");
const heroImg = assetPath("images/hero-driver.jpg");
const before = assetPath("images/before.png");
const after = assetPath("images/after.png");

const metrics = [
  { value: "1,200件+", label: "累計対応実績", note: "2026年4月時点・自社集計" },
  { value: "98%", label: "お客様満足度", note: "自社アンケート集計" },
  { value: "最短30分", label: "訪問相談の目安", note: "混雑状況・エリアにより変動" },
];

const answerCards = [
  {
    title: "何を頼める？",
    body: "家電・家具・ブランド品の出張買取、不用品回収、遺品整理、残置物撤去までまとめて対応します。",
  },
  {
    title: "費用は？",
    body: "出張費・見積もり・査定費は無料。まず価格感だけ知りたい場合もご相談いただけます。",
  },
  {
    title: "どれくらい早い？",
    body: "名古屋市内を中心に最短30分で相談可能。お急ぎ案件にも柔軟に対応します。",
  },
  {
    title: "どう相談する？",
    body: "電話ならすぐに日程調整、LINEなら写真を送るだけで概算の相談ができます。",
  },
  {
    title: "どこまで来る？",
    body: "名古屋市全域と近郊エリア、一部三重県まで対応。市外案件もまずはご相談ください。",
  },
  {
    title: "どんな会社？",
    body: "名古屋市中区を拠点に活動する徳丸商会。古物商許可を取得し、地域密着で対応しています。",
  },
];

const scenarios = [
  {
    title: "引越し前で時間がない",
    body: "冷蔵庫や洗濯機の買取と、不用品の回収を同日にまとめて進めたい方に向いています。",
  },
  {
    title: "重い物が運べない",
    body: "大型家具や家電もスタッフが養生して搬出。ご自身で運ぶ必要はありません。",
  },
  {
    title: "片付けごと一括で頼みたい",
    body: "価値がある物は買取し、残りは回収や整理へ。その場で方針をまとめて決められます。",
  },
];

const services = [
  {
    title: "出張買取",
    accent: "高く売りたい",
    body: "家電・家具・ブランド品・貴金属を、ご自宅で査定してその場で現金化。持ち込み不要で進められます。",
  },
  {
    title: "不用品回収",
    accent: "まとめて片付けたい",
    body: "引越し前の大量処分、部屋の整理、家財の入れ替え時の回収まで対応。買取額で負担を抑えられるケースもあります。",
  },
  {
    title: "遺品整理",
    accent: "丁寧に進めたい",
    body: "思い出の品を扱う前提で、仕分け・回収・買取の流れを整理。ご家族の負担を減らす進め方ができます。",
  },
  {
    title: "残置物撤去",
    accent: "退去前に整えたい",
    body: "賃貸物件や空き家、管理物件の残置物撤去にも対応。法人・管理会社からのご相談も受けています。",
  },
];

const reasons = [
  {
    title: "急ぎの片付けでも話が進みやすい",
    body: "査定、訪問、搬出までの流れが早く、引越し前や退去前でも止まりにくい進め方ができます。",
  },
  {
    title: "売る物と片付ける物を一緒に整理できる",
    body: "売れる物は買取、残る物は回収へ。その場で全体の方針をまとめて決められます。",
  },
  {
    title: "まず相談だけでも頼みやすい",
    body: "価格だけ聞きたい、まず写真で確認したいという段階から受けられる体制です。",
  },
  {
    title: "名古屋密着で安心して任せやすい",
    body: "名古屋市中区を拠点に動いているため、エリア感が合いやすく、相談や日程調整も進めやすいです。",
  },
];

const steps = [
  {
    number: "01",
    title: "電話・LINEでご相談",
    body: "品目、量、エリア、希望日時を伺います。LINEなら写真を送るだけで相談を始められます。",
  },
  {
    number: "02",
    title: "訪問・内容確認",
    body: "現地で品物や作業量を確認し、買取・回収・整理の進め方をわかりやすく案内します。",
  },
  {
    number: "03",
    title: "査定・お支払い",
    body: "査定額にご納得いただければ、その場で現金でお支払い。処分が必要な物も続けて対応します。",
  },
  {
    number: "04",
    title: "搬出・片付け完了",
    body: "大型家電や家具もスタッフが搬出。ご自身で運ぶ手間なく、その日のうちに整理を進められます。",
  },
];

const results = [
  { name: "冷蔵庫", detail: "大型 500L以上", price: "39,000", img: assetPath("images/results/refrigerator.png"), alt: "大型冷蔵庫の高額買取事例" },
  { name: "洗濯機", detail: "ドラム式", price: "24,500", img: assetPath("images/results/washing-machine.png"), alt: "ドラム式洗濯機の高額買取事例" },
  { name: "エアコン", detail: "取外し込み", price: "21,000", img: assetPath("images/results/aircon.png"), alt: "エアコンの高額買取事例" },
  { name: "テレビ", detail: "55インチ", price: "17,000", img: assetPath("images/results/tv.jpg"), alt: "液晶テレビの高額買取事例" },
];

const voices = [
  {
    category: "引越し前の片付け",
    text: "前日になってからの相談でしたが、回収と買取をまとめて進めてもらえたので退去準備が一気に楽になりました。",
    who: "名古屋市中区 T.S様",
  },
  {
    category: "大型家電の買取",
    text: "LINEで写真を送って流れが分かったうえでお願いできたので安心でした。重い冷蔵庫も手際よく搬出してもらえました。",
    who: "名古屋市緑区 M.K様",
  },
  {
    category: "片付けと査定の同時相談",
    text: "売れる物と回収した方がいい物をその場で整理してくれたので、迷わず進められました。説明も丁寧でした。",
    who: "あま市 Y.N様",
  },
];

const wards = ["千種区","東区","北区","西区","中村区","中区","昭和区","瑞穂区","熱田区","中川区","港区","南区","守山区","緑区","名東区","天白区"];
const nearbyAreas = ["あま市","清須市","北名古屋市","津島市","愛西市","弥富市","東海市","大府市","刈谷市","豊明市","四日市市"];
---

<Layout
  title="名古屋で出張買取・不用品回収・遺品整理を頼むなら徳丸商会"
  description="名古屋市中区の徳丸商会。家電・家具・ブランド品の出張買取、不用品回収、遺品整理、残置物撤去まで対応。出張費・見積もり無料、最短30分で相談可能。"
  includeTopSchemas={true}
>
  <header class="fixed inset-x-0 top-0 z-50 border-b border-white/10 bg-slate/86 backdrop-blur-xl">
    <div class="max-w-6xl mx-auto px-5 h-16 flex items-center justify-between">
      <a href={homePath} class="flex items-center gap-3">
        <img src={logo} alt="徳丸商会" width="36" height="36" class="w-9 h-9" />
        <div>
          <p class="text-white text-sm font-bold leading-none">徳丸商会</p>
          <p class="text-gold-light text-[10px] tracking-[0.12em] mt-1">名古屋の出張買取・不用品回収</p>
        </div>
      </a>

      <nav class="hidden lg:flex items-center gap-6 text-xs text-white/70">
        <a href={sectionPath("answers")} class="hover:text-white transition-colors">早わかり</a>
        <a href={sectionPath("service")} class="hover:text-white transition-colors">サービス</a>
        <a href={sectionPath("results")} class="hover:text-white transition-colors">買取実績</a>
        <a href={sectionPath("company")} class="hover:text-white transition-colors">会社情報</a>
        <a href={sectionPath("faq")} class="hover:text-white transition-colors">よくある質問</a>
      </nav>

      <div class="flex items-center gap-2">
        <a
          href={`tel:${company.phone}`}
          class="inline-flex items-center justify-center rounded-full bg-red hover:bg-red-light text-white font-bold text-xs px-4 py-2.5 transition-colors"
        >
          <span class="hidden sm:inline">{company.phone}</span>
          <span class="sm:hidden">電話</span>
        </a>
        <a
          href={company.lineUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center rounded-full bg-line hover:opacity-90 text-white font-bold text-xs px-4 py-2.5 transition-opacity"
        >
          LINE査定
        </a>
      </div>
    </div>
  </header>

  <main class="pt-16">
    <section class="relative overflow-hidden bg-slate text-white">
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(214,179,107,0.2),transparent_32%),linear-gradient(135deg,rgba(19,33,42,1)_0%,rgba(19,33,42,0.96)_52%,rgba(32,53,67,0.94)_100%)]"></div>
      <div class="absolute inset-y-0 right-0 hidden lg:block w-[44%] bg-[linear-gradient(90deg,rgba(19,33,42,0)_0%,rgba(19,33,42,0.5)_12%,rgba(19,33,42,0.1)_100%)]"></div>

      <div class="relative max-w-6xl mx-auto px-5 py-14 md:py-24 grid lg:grid-cols-[minmax(0,1.08fr)_minmax(360px,0.92fr)] gap-10 items-center">
        <div class="reveal-up">
          <p class="eyebrow mb-5">名古屋の出張買取・不用品回収</p>
          <h1 class="font-display text-[2.35rem] md:text-6xl leading-[1.06] tracking-[0.01em] mb-5">
            出張買取も
            <span class="text-gold-light">不用品回収</span>
            も
            <br />
            遺品整理も、
            <br />
            一度で片づく
          </h1>
          <p class="text-white/76 text-sm md:text-lg max-w-2xl leading-[1.95] mb-7">
            名古屋市中区を拠点に、家電・家具・ブランド品の出張買取から、
            引越し前の不用品回収、遺品整理、残置物撤去までワンストップで対応。
            持ち込み不要で、まずは価格感だけ知りたいご相談から受け付けています。
          </p>

          <div class="flex flex-wrap gap-2.5 mb-7">
            <span class="rounded-full border border-white/12 bg-white/7 px-4 py-2 text-xs text-white/78">出張費・見積もり無料</span>
            <span class="rounded-full border border-white/12 bg-white/7 px-4 py-2 text-xs text-white/78">最短30分で相談可能</span>
            <span class="rounded-full border border-white/12 bg-white/7 px-4 py-2 text-xs text-white/78">査定だけの相談も可</span>
          </div>

          <div class="flex flex-col sm:flex-row gap-3 mb-5 reveal-up reveal-up-delay-1">
            <a
              href={`tel:${company.phone}`}
              class="inline-flex items-center justify-center rounded-2xl bg-red hover:bg-red-light text-white font-black text-base md:text-lg px-8 py-4 transition-colors shadow-[0_20px_50px_rgba(188,75,53,0.28)] pulse-glow"
            >
              今すぐ電話で相談する
            </a>
            <a
              href={company.lineUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center rounded-2xl bg-line hover:brightness-110 text-white font-bold text-base md:text-lg px-8 py-4 transition-all shadow-[0_18px_40px_rgba(6,199,85,0.24)]"
            >
              LINEで写真を送る
            </a>
          </div>

          <p class="text-[11px] md:text-xs text-white/45">
            受付 {company.hours} / 古物商許可 {company.permitNumber} / 2026年4月時点の自社集計値を掲載
          </p>
        </div>

        <div class="relative reveal-fade reveal-up-delay-2">
          <div class="panel-soft rounded-[2rem] p-3 md:p-4 float-slow">
            <img
              src={heroImg}
              alt="名古屋エリアの出張買取に向かう徳丸商会スタッフ"
              class="w-full aspect-[4/5] md:aspect-[11/12] rounded-[1.5rem] object-cover"
              loading="eager"
            />
          </div>

          <div class="panel-dark rounded-[1.5rem] p-5 md:p-6 absolute -left-2 md:-left-10 bottom-4 md:bottom-8 max-w-[18rem]">
            <p class="text-gold-light text-xs font-bold tracking-[0.14em] mb-2">まとめて頼める安心感</p>
            <p class="font-display text-2xl text-white leading-tight mb-3">
              売れる物は買取、
              <br />
              残る物は回収へ
            </p>
            <p class="text-white/68 text-sm leading-[1.85]">
              ひとつの窓口で進められるから、複数業者に分けて手配する必要がありません。
            </p>
          </div>

          <div class="panel-soft rounded-[1.35rem] p-4 absolute right-0 md:-right-6 -top-3 md:top-10 max-w-[14rem] hidden sm:block">
            <p class="text-[11px] font-bold tracking-[0.12em] text-gold mb-2">名古屋市中区を拠点に対応</p>
            <p class="text-text font-bold text-sm leading-snug mb-2">{company.locality}</p>
            <p class="text-text-light text-xs leading-[1.7]">{company.serviceSummary}</p>
          </div>
        </div>
      </div>
    </section>

    <section class="section-frame py-10 md:py-14">
      <div class="relative max-w-6xl mx-auto px-5">
        <div class="grid gap-4 md:grid-cols-3">
          {metrics.map((metric) => (
            <div class="panel-soft rounded-[1.5rem] p-6 text-center reveal-up">
              <p class="font-display text-3xl md:text-[2.6rem] text-slate leading-none mb-2">{metric.value}</p>
              <p class="text-text font-bold text-sm mb-1">{metric.label}</p>
              <p class="text-text-lighter text-xs">{metric.note}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section id="answers" class="py-14 md:py-20">
      <div class="max-w-6xl mx-auto px-5">
        <div class="max-w-3xl mb-10">
          <p class="eyebrow mb-4">名古屋で頼む前に知りたいこと</p>
          <h2 class="font-display text-3xl md:text-5xl text-slate leading-[1.15] mb-4">
            出張買取・不用品回収を
            <br />
            まずは短く整理
          </h2>
          <p class="text-text-light text-sm md:text-base max-w-2xl">
            何を頼めるのか、いくらかかるのか、どれくらい早いのか。問い合わせ前に気になる点を、先に短く確認できる構成にしています。
          </p>
        </div>

        <div class="grid md:grid-cols-2 xl:grid-cols-3 gap-4 md:gap-5">
          {answerCards.map((card) => (
            <div class="panel-soft rounded-[1.5rem] p-6 reveal-up">
              <p class="text-gold font-bold text-[11px] tracking-[0.18em] mb-3">{card.title}</p>
              <p class="text-text text-sm md:text-base leading-[1.9]">{card.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="py-14 md:py-20 bg-bg-white border-y border-border/70">
      <div class="max-w-6xl mx-auto px-5">
        <div class="grid lg:grid-cols-[minmax(0,0.9fr)_minmax(0,1.1fr)] gap-10 items-start">
          <div>
          <p class="eyebrow mb-4">こんな場面に強い</p>
          <h2 class="font-display text-3xl md:text-5xl text-slate leading-[1.15] mb-4">
            急ぎの片付けでも
            <br />
            流れが止まりにくい
          </h2>
          <p class="text-text-light text-sm md:text-base leading-[1.9]">
            ただ高く売るだけでなく、片付けの流れそのものが前に進むことを重視しています。引越し前、退去前、遺品整理など、判断が多く発生する場面で使いやすい構成です。
          </p>
        </div>

          <div class="grid md:grid-cols-3 gap-4">
            {scenarios.map((scenario) => (
              <div class="rounded-[1.5rem] border border-border bg-bg p-5 reveal-up">
                <p class="text-slate font-bold text-base mb-3">{scenario.title}</p>
                <p class="text-text-light text-sm leading-[1.85]">{scenario.body}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section id="service" class="py-14 md:py-20">
      <div class="max-w-6xl mx-auto px-5">
        <div class="max-w-3xl mb-10">
          <p class="eyebrow mb-4">対応サービス</p>
          <h2 class="font-display text-3xl md:text-5xl text-slate leading-[1.15] mb-4">
            出張買取・不用品回収・
            <br />
            遺品整理を一括対応
          </h2>
          <p class="text-text-light text-sm md:text-base max-w-2xl">
            徳丸商会では、出張買取だけでなく、その周辺で発生する回収や整理まで含めて対応しています。売るか処分するか迷っている段階でも問題ありません。
          </p>
        </div>

        <div class="grid md:grid-cols-2 xl:grid-cols-4 gap-5">
          {services.map((service, index) => (
            <article class:list={[
              "rounded-[1.6rem] border p-6 shadow-[0_18px_42px_rgba(19,33,42,0.06)] reveal-up",
              index === 0 ? "bg-slate text-white border-slate" : "bg-bg-white border-border"
            ]}>
              <p class:list={[ "text-[11px] font-bold tracking-[0.18em] mb-3", index === 0 ? "text-gold-light" : "text-gold" ]}>
                {service.accent}
              </p>
              <h3 class:list={[ "font-bold text-lg mb-3", index === 0 ? "text-white" : "text-slate" ]}>
                {service.title}
              </h3>
              <p class:list={[ "text-sm leading-[1.9]", index === 0 ? "text-white/74" : "text-text-light" ]}>
                {service.body}
              </p>
            </article>
          ))}
        </div>

        <div class="mt-8 panel-soft rounded-[1.7rem] p-6 md:p-8 max-w-4xl">
          <p class="text-gold font-bold text-[11px] tracking-[0.14em] mb-3">出張買取とは</p>
          <p class="text-text text-sm md:text-base leading-[2]">
            <strong class="text-slate">出張買取とは</strong>、お客様のご自宅や現場にスタッフが訪問し、品物をその場で査定・買取するサービスです。
            徳丸商会では名古屋市を中心に、不用品回収、遺品整理、残置物撤去まで同時に相談できるため、
            「売れる物」と「片付けが必要な物」を一つの窓口で整理できます。
          </p>
        </div>
      </div>
    </section>

    <section class="py-14 md:py-20 bg-slate text-white">
      <div class="max-w-6xl mx-auto px-5">
        <div class="max-w-3xl mb-10">
          <p class="eyebrow mb-4">選ばれる理由</p>
          <h2 class="font-display text-3xl md:text-5xl leading-[1.15] mb-4">
            迫力だけでなく、
            <br />
            安心して任せやすい
          </h2>
          <p class="text-white/68 text-sm md:text-base max-w-2xl">
            価格訴求だけではなく、相談しやすさ、判断のしやすさ、現場対応の安心感まで含めて、依頼しやすい見せ方に整えています。
          </p>
        </div>

        <div class="grid lg:grid-cols-[minmax(0,1fr)_minmax(270px,0.42fr)] gap-6">
          <div class="grid md:grid-cols-2 gap-4">
            {reasons.map((reason, index) => (
              <div class="rounded-[1.5rem] border border-white/10 bg-white/6 p-6 reveal-up">
                <p class="text-gold-light font-bold text-sm mb-3">0{index + 1}</p>
                <h3 class="font-bold text-base mb-3">{reason.title}</h3>
                <p class="text-white/70 text-sm leading-[1.85]">{reason.body}</p>
              </div>
            ))}
          </div>

          <aside class="rounded-[1.8rem] border border-gold/20 bg-[linear-gradient(180deg,rgba(214,179,107,0.12),rgba(255,255,255,0.04))] p-6">
            <p class="text-gold-light font-bold text-[11px] tracking-[0.14em] mb-3">事業者情報</p>
            <p class="font-display text-2xl leading-tight mb-5">名古屋密着だから、相談しやすい。</p>
            <dl class="space-y-4 text-sm">
              <div>
                <dt class="text-white/45">拠点</dt>
                <dd class="font-bold text-white">{company.locality}</dd>
              </div>
              <div>
                <dt class="text-white/45">受付時間</dt>
                <dd class="font-bold text-white">{company.hours}</dd>
              </div>
              <div>
                <dt class="text-white/45">古物商許可番号</dt>
                <dd class="font-bold text-white">{company.permitNumber}</dd>
              </div>
            </dl>
          </aside>
        </div>
      </div>
    </section>

    <section class="py-14 md:py-20 bg-bg-white">
      <div class="max-w-6xl mx-auto px-5">
        <div class="max-w-3xl mb-10">
          <p class="eyebrow mb-4">ご依頼の流れ</p>
          <h2 class="font-display text-3xl md:text-5xl text-slate leading-[1.15] mb-4">
            連絡から搬出まで、
            <br />
            迷わず進められる
          </h2>
          <p class="text-text-light text-sm md:text-base max-w-2xl">
            初めて依頼する方でも工程をイメージしやすいよう、相談から搬出までを順番に整理しています。
          </p>
        </div>

        <div class="grid md:grid-cols-2 xl:grid-cols-4 gap-4">
          {steps.map((step) => (
            <div class="rounded-[1.5rem] border border-border bg-bg p-5 reveal-up">
              <div class="w-12 h-12 rounded-full bg-slate text-white flex items-center justify-center font-black text-sm mb-4">
