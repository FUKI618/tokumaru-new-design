</section>

<!-- ═══════════════════════════════════════════════ -->
<!--  CAMPAIGN BANNER: ヒーロー直下で訴求最大化       -->
<!-- ═══════════════════════════════════════════════ -->
<section id="campaign" class="relative py-6 md:py-7 bg-gradient-to-r from-terra via-amber to-terra text-white overflow-hidden border-y border-amber-light/30">
  <!-- Marquee shimmer 装飾 -->
  <div class="absolute inset-0 bg-[linear-gradient(45deg,transparent_30%,rgba(255,255,255,0.18)_50%,transparent_70%)] bg-[length:200%_100%] animate-pulse pointer-events-none" style="animation-duration:3s"></div>

  <div class="relative max-w-5xl mx-auto px-5 flex flex-col md:flex-row items-center gap-3 md:gap-6">
    <!-- 左: ラベル+数字 -->
    <div class="flex items-center gap-3 md:gap-4 flex-shrink-0">
      <span class="inline-flex items-center justify-center w-12 h-12 md:w-14 md:h-14 rounded-full bg-white/20 backdrop-blur-sm border border-white/40 text-white font-black text-xs md:text-sm flex-shrink-0 shadow-lg badge-pulse">
        SALE
      </span>
      <div class="text-left">
        <p class="text-white/90 font-bold text-xs md:text-sm leading-tight">期間限定キャンペーン実施中</p>
        <p class="text-white font-black text-2xl md:text-4xl leading-none mt-0.5">
          最大<span class="text-white drop-shadow-[0_2px_8px_rgba(255,255,255,0.5)]">5%</span>OFF
        </p>
