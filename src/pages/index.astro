      <div class="inline-flex items-center gap-1.5 bg-gradient-to-r from-terra/30 to-amber/30 border border-amber/50 text-amber-light rounded-full px-3 py-1 text-[11px] font-bold mb-3 badge-pulse">
        <span class="relative flex h-1.5 w-1.5"><span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-amber opacity-75"></span><span class="relative inline-flex rounded-full h-1.5 w-1.5 bg-amber-light"></span></span>
        <span>キャンペーン中</span>
        <span class="text-white/40">／</span>
        <span class="text-gradient font-black">最大5%OFF</span>
      </div>
      <p class="text-[2.1rem] font-black leading-[1.15] mb-2 text-white" style="text-shadow: 0 2px 12px rgba(0,0,0,0.8), 0 0 30px rgba(0,0,0,0.4);">
