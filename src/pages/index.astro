        <a href={sectionPath(item.id)} class="text-white/60 hover:text-white hover:bg-white/5 text-[1.05cqw] font-bold px-[1cqw] py-[0.65cqw] rounded-lg transition-all">{item.label}</a>
      ))}
    </nav><div class="flex items-center gap-[1.6vw] md:gap-[0.8cqw]">
