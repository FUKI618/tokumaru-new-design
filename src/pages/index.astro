    </div>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-3 md:gap-5 stagger-children">
      {[
        { name: "単品回収", price: "1,500", note: "椅子・小型家電など1点から", icon: "M12 2L2 7l10 5 10-5-10-5z" },
        { name: "軽トラ1台分", price: "11,000", note: "1K〜1Rの片付けに", icon: "M3 17h2.5l1-3h11l1 3H21V8H3z M5 11h14" },
