        { name: "2tトラック1台分", price: "53,000", note: "戸建て一括・遺品整理に", icon: "M2 17h20 M4 17l-2-9h20l-2 9 M6 13h12" },
      ].map((p) => (
        <div class="reveal reveal-scale bg-white rounded-2xl border border-border shadow-sm p-5 md:p-6 card-hover">
          <div class="w-10 h-10 md:w-12 md:h-12 bg-gradient-to-br from-terra to-amber rounded-xl flex items-center justify-center mb-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 md:w-6 md:h-6 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d={p.icon}/>
            </svg>
          </div>
          <h3 class="text-text font-bold text-sm md:text-base mb-2">{p.name}</h3>
          <p class="text-terra font-black text-xl md:text-2xl leading-none mb-2">¥{p.price}<span class="text-xs md:text-sm font-bold ml-0.5">〜</span></p>
          <p class="text-text-lighter text-[11px] md:text-xs leading-relaxed">{p.note}</p>
        </div>
      ))}
    </div>

    <p class="text-text-lighter text-xs mt-5 text-center">
      ※搬出経路・量・お住まいの階層により金額が前後します。家電リサイクル法対象品（冷蔵庫・洗濯機・エアコン・テレビ）は買取成立時はリサイクル料も0円。
    </p>

    <!-- ═══ キャンペーン詳細：クーポン型カード（直接CTA一体化） ═══ -->
    <div id="campaign-detail" class="mt-12 md:mt-16 reveal reveal-up scroll-mt-20">
      <div class="text-center mb-7 md:mb-9">
        <p class="text-terra text-xs font-bold tracking-widest uppercase mb-2">Campaign</p>
        <h3 class="text-xl md:text-3xl font-black text-text mb-2">期間限定 <span class="text-gradient">5%OFFキャンペーン</span></h3>
        <p class="text-text-light text-sm">下記いずれかの条件で適用。今月のご相談分が対象です。</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-5 max-w-4xl mx-auto stagger-children">
        {company.campaigns.map((c) => {
          const isLine = c.colorClass === "line";
          const accent = isLine ? "from-line to-line" : "from-terra to-amber";
          const ctaBg = isLine ? "bg-line hover:brightness-110" : "bg-terra hover:bg-terra-light";
          return (
            <div class="reveal reveal-scale relative bg-white rounded-2xl p-5 md:p-6 shadow-lg card-hover border-2 border-dashed border-terra/30 overflow-hidden">
              <!-- リボン -->
              <div class={`absolute -top-1 -right-1 z-10 bg-gradient-to-br ${accent} text-white text-[10px] md:text-xs font-black px-3 py-1 shadow-md rounded-bl-lg rounded-tr-2xl`}>
                LIMITED
              </div>
              <!-- ハサミ装飾線(クーポン感) -->
              <div class="absolute left-0 top-1/2 -translate-y-1/2 w-3 h-3 rounded-full bg-bg border-2 border-terra/30"></div>
              <div class="absolute right-0 top-1/2 -translate-y-1/2 w-3 h-3 rounded-full bg-bg border-2 border-terra/30"></div>

              <p class="text-text-lighter text-[11px] md:text-xs font-bold mb-1">{c.catch}</p>
              <p class="text-text font-bold text-base md:text-lg mb-3 leading-tight">{c.title}</p>

              <!-- 巨大%数字 -->
              <div class="flex items-baseline gap-1 mb-3">
                <span class="text-gradient font-black text-5xl md:text-6xl leading-none">{c.discount}</span>
                <span class="text-terra font-black text-2xl md:text-3xl leading-none">{c.unit}</span>
                <span class="text-terra font-black text-xl md:text-2xl ml-1">{c.suffix}</span>
              </div>

              <p class="text-text-light text-xs md:text-sm leading-relaxed mb-4">{c.description}</p>

              <!-- 専用CTA -->
              <a
                href={c.actionHref}
                {...(c.actionExternal ? { target: "_blank", rel: "noopener noreferrer" } : {})}
                class={`inline-flex items-center justify-center gap-2 w-full ${ctaBg} text-white font-bold text-sm md:text-base px-5 py-3 rounded-xl shadow-md transition-all`}
              >
                <span>{c.actionLabel}で適用</span>
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg>
              </a>

              <p class="text-text-lighter text-[10px] md:text-[11px] mt-3 text-center">{c.note}</p>
            </div>
          );
        })}
      </div>

      <p class="text-center text-text-light text-xs md:text-sm mt-6">
        ご相談時に「<strong class="text-terra">キャンペーンを見た</strong>」とお伝えください。LINE経由のお問い合わせは自動適用となります。
      </p>
    </div>
  </div>
</section>

