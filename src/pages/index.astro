---
import Layout from "../layouts/Layout.astro";
import { assetPath, homePath, sectionPath, privacyPolicyPath, areaPath, areaIndexPath } from "../lib/site";
import { faqs } from "../data/faq";
import { groupAreasByRegion, regionLabels, type AreaRegion } from "../data/areas";
import { company } from "../data/company";
import { competitiveEdges } from "../data/competitive";

const areaGroups = groupAreasByRegion();
const areaRegionOrder: AreaRegion[] = ["nagoya", "owari", "chita", "mikawa", "mie"];

const logo = assetPath("logo.svg");
const logoClean = assetPath("logo.svg");
const heroImg = assetPath("images/hero-staff.webp");
const case1Before = assetPath("images/case1-before.webp");
