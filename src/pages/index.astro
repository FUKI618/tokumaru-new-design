</section>

<!-- ═══ 信頼バー ═══ -->
<section class="py-10 md:py-14 bg-bg-cream border-y border-border relative overflow-hidden" x-data x-init="
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        e.target.querySelectorAll('.count-up').forEach((el, i) => {
          setTimeout(() => el.classList.add('visible'), i * 150);
        });
        e.target.querySelectorAll('[data-count]').forEach(el => {
          const target = parseInt(el.dataset.count);
          let current = 0;
          const step = Math.ceil(target / 40);
          const timer = setInterval(() => {
            current += step;
            if (current >= target) { current = target; clearInterval(timer); }
            el.textContent = current.toLocaleString();
          }, 30);
        });
        observer.disconnect();
      }
    });
  }, { threshold: 0.5 });
  observer.observe($el);
">
  <div class="max-w-4xl mx-auto px-5">
    <div class="grid grid-cols-3 gap-2.5 md:gap-6">
      <div class="count-up bg-white rounded-xl md:rounded-2xl px-2 py-3 md:p-6 border border-border shadow-sm text-center relative overflow-hidden">
        <div class="absolute top-0 inset-x-0 h-1 bg-gradient-to-r from-terra to-amber"></div>
        <p class="text-terra font-black text-2xl md:text-5xl leading-none mt-1"><span data-count="30000">0</span></p>
        <p class="text-terra text-[10px] md:text-sm font-bold">件+</p>
        <p class="text-text-lighter text-[9px] md:text-xs mt-1">累計買取実績</p>
      </div>
      <div class="count-up bg-white rounded-xl md:rounded-2xl px-2 py-3 md:p-6 border border-border shadow-sm text-center relative overflow-hidden">
        <div class="absolute top-0 inset-x-0 h-1 bg-gradient-to-r from-terra to-amber"></div>
        <p class="text-terra font-black text-2xl md:text-5xl leading-none mt-1"><span data-count="98">0</span></p>
        <p class="text-terra text-[10px] md:text-sm font-bold">%</p>
        <p class="text-text-lighter text-[9px] md:text-xs mt-1">お客様満足度</p>
      </div>
      <div class="count-up bg-white rounded-xl md:rounded-2xl px-2 py-3 md:p-6 border border-border shadow-sm text-center relative overflow-hidden">
        <div class="absolute top-0 inset-x-0 h-1 bg-gradient-to-r from-terra to-amber"></div>
        <p class="text-terra font-black text-2xl md:text-5xl leading-none mt-1">0</p>
        <p class="text-terra text-[10px] md:text-sm font-bold">円</p>
        <p class="text-text-lighter text-[9px] md:text-xs mt-1">出張費・査定費</p>
