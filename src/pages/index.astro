      <img src={brandSeal} alt="" width="56" height="56" class="w-[9.3vw] h-[9.3vw] md:w-[4.95cqw] md:h-[4.95cqw] transition-transform group-hover:scale-105" /><div class="flex flex-col">
        <img src={brandWordmark} alt="徳丸商会" width="580" height="136" class="h-[6.4vw] md:h-[3.1cqw] w-auto" />
        <span class="text-white/60 text-[2.3vw] md:text-[1.25cqw] font-bold leading-tight whitespace-nowrap mt-[0.8vw] md:mt-[0.3cqw]">名古屋の出張買取・不用品回収</span>
      </div>
    </a>
    <nav class="hidden lg:flex items-center gap-1">{[
        { label: "サービス", id: "service" },
        { label: "買取実績", id: "results" },
        { label: "対応エリア", id: "area" },
        { label: "FAQ", id: "faq" },
