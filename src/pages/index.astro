---
import Layout from "../layouts/Layout.astro";
import { assetPath, homePath, sectionPath, privacyPolicyPath } from "../lib/site";
import { faqs } from "../data/faq";

const logo = assetPath("logo.png");
const logoClean = assetPath("logo-clean.png");
const heroImg = assetPath("images/hero-staff.jpg");
const before = assetPath("images/before-room.jpg");
const after = assetPath("images/after-room.jpg");
const serviceCarry = assetPath("images/service-carry.jpg");
const serviceEstate = assetPath("images/service-estate.jpg");
const truckLoading = assetPath("images/truck-loading.jpg");
const results = [
  { name: "冷蔵庫", detail: "大型 500L以上", price: "39,000", img: assetPath("images/results/refrigerator.jpg") },
  { name: "洗濯機", detail: "ドラム式", price: "24,500", img: assetPath("images/results/washing-machine.jpg") },
  { name: "エアコン", detail: "取外し込み", price: "21,000", img: assetPath("images/results/aircon.jpg") },
  { name: "テレビ", detail: "55インチ", price: "17,000", img: assetPath("images/results/tv.jpg") },
];
const voices = [
  { text: "引越し前日に慌てて電話しましたが、2時間後には全部片付きました。思った以上の金額で買い取ってもらえました。", who: "名古屋市中区 T.S様", stars: 5 },
  { text: "LINEで写真を送ったらすぐに概算が出て、翌日には訪問してもらえました。重い冷蔵庫の搬出も手際よかったです。", who: "名古屋市緑区 M.K様", stars: 5 },
  { text: "他社で断られた古い家具も査定してくれて、値段がついたのは驚きでした。家族にも勧めています。", who: "あま市 Y.N様", stars: 5 },
];
const areas = ["千種区","東区","北区","西区","中村区","中区","昭和区","瑞穂区","熱田区","中川区","港区","南区","守山区","緑区","名東区","天白区"];
const nearby = ["あま市","清須市","北名古屋市","津島市","愛西市","弥富市","東海市","大府市","刈谷市","豊明市","四日市市"];
---

<Layout
  title="名古屋の出張買取・不用品回収なら徳丸商会｜出張費無料"
  description="名古屋市・近郊エリアの出張買取は徳丸商会へ。家電・家具・ブランド品をその場で現金買取。不用品回収・遺品整理も対応。出張費0円。052-990-3968"
>

<!-- ═══════════════════════════════════════════════ -->
<!--  HEADER                                        -->
<!-- ═══════════════════════════════════════════════ -->
<header class="fixed top-0 inset-x-0 z-50 bg-dark/95 backdrop-blur-md shadow-lg border-b border-white/5">
  <div class="max-w-6xl mx-auto px-5 h-14 flex items-center justify-between">
    <a href={homePath} class="flex items-center gap-2 group">
      <img src={logo} alt="徳丸商会" width="32" height="32" class="w-8 h-8 transition-transform group-hover:scale-110" />
      <span class="text-white font-bold text-sm">徳丸商会</span>
    </a>
    <nav class="hidden md:flex items-center gap-6 text-xs text-white/60">
      <a href={sectionPath("service")} class="hover:text-terra-light transition-colors">サービス</a>
      <a href={sectionPath("results")} class="hover:text-terra-light transition-colors">買取実績</a>
      <a href={sectionPath("area")} class="hover:text-terra-light transition-colors">対応エリア</a>
      <a href={sectionPath("faq")} class="hover:text-terra-light transition-colors">FAQ</a>
    </nav>
    <div class="flex items-center gap-2">
      <a href="tel:052-990-3968" class="flex items-center gap-1.5 bg-terra hover:bg-terra-light text-white font-bold text-xs px-4 py-2 rounded-lg transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        <span class="hidden sm:inline">052-990-3968</span>
      </a>
      <a href="https://lin.ee/j4wK9IM" target="_blank" rel="noopener noreferrer" class="bg-line hover:brightness-110 text-white font-bold text-xs px-4 py-2 rounded-lg transition-all">LINE査定</a>
    </div>
  </div>
</header>

<main class="pt-14">

<!-- ═══════════════════════════════════════════════ -->
<!--  HERO: 迫力ある全面背景 + パーティクル          -->
<!-- ═══════════════════════════════════════════════ -->
<section class="relative min-h-[90vh] md:min-h-[85vh] bg-dark text-white overflow-hidden flex items-center">
  <!-- Background Image (full bleed) -->
  <img src={heroImg} alt="" class="absolute inset-0 w-full h-full object-cover opacity-40" loading="eager" />
  <!-- Multi-layer gradient overlay -->
  <div class="absolute inset-0 bg-gradient-to-r from-dark via-dark/90 to-dark/40"></div>
  <div class="absolute inset-0 bg-gradient-to-t from-dark via-transparent to-dark/50"></div>
  <!-- Logo watermark -->
  <img src={logoClean} alt="" class="logo-watermark w-[450px] md:w-[700px] opacity-[0.10]" aria-hidden="true" />
  <!-- Floating particles -->
  <div class="hero-particles">
    <span></span><span></span><span></span><span></span>
    <span></span><span></span><span></span><span></span>
  </div>

  <div class="relative max-w-6xl mx-auto px-5 py-16 md:py-24 w-full">
    <div class="max-w-2xl">
      <!-- Badge -->
      <div class="inline-flex items-center gap-2 bg-terra/20 border border-terra/40 text-terra-light rounded-full px-4 py-1.5 text-xs font-bold mb-6 badge-pulse">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-terra opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-terra-light"></span>
        </span>
        買取強化中 ― お早めにご相談を
      </div>

      <!-- Logo + Name -->
      <div class="flex items-center gap-3 mb-5">
        <img src={logo} alt="徳丸商会" width="56" height="56" class="w-12 h-12 md:w-14 md:h-14 drop-shadow-lg" />
        <div>
          <span class="text-white font-black text-xl md:text-2xl">徳丸商会</span>
          <span class="text-terra-light text-xs md:text-sm font-bold ml-2">名古屋の出張買取</span>
        </div>
      </div>

      <!-- H1: 迫力のタイポグラフィ -->
      <h1 class="text-4xl md:text-6xl lg:text-7xl font-black leading-[1.05] mb-4 tracking-tight">
        <span class="block">名古屋の出張買取・</span>
        <span class="block">不用品回収なら</span>
        <span class="block text-gradient mt-1">徳丸商会</span>
      </h1>

      <!-- Mobile hero image -->
      <div class="md:hidden my-6 rounded-xl overflow-hidden shadow-2xl border border-white/10">
        <img src={heroImg} alt="出張買取に向かうスタッフ" class="w-full aspect-[16/9] object-cover" loading="eager" />
      </div>

      <p class="text-white/55 text-sm md:text-base mb-8 max-w-md leading-relaxed">
        家電・家具・ブランド品の出張買取から、不用品回収・遺品整理まで。<br class="hidden md:inline" />お電話一本で即日対応いたします。
      </p>

      <!-- 選ばれる3つの理由 -->
      <div class="bg-white/[0.07] backdrop-blur-md rounded-2xl p-5 md:p-6 border border-white/10 mb-8 max-w-xl">
        <p class="text-terra-light text-xs font-bold text-center mb-4 tracking-wider uppercase">Why Choose Us</p>
        <div class="grid grid-cols-3 gap-4 text-center">
          <div>
            <div class="w-14 h-14 mx-auto mb-2 rounded-full bg-gradient-to-br from-terra to-amber flex items-center justify-center shadow-lg">
              <span class="text-white font-black text-sm">¥UP</span>
            </div>
            <p class="text-white text-xs leading-tight font-bold">どこよりも<br />高価買取</p>
          </div>
          <div>
            <div class="w-14 h-14 mx-auto mb-2 rounded-full bg-gradient-to-br from-terra to-amber flex items-center justify-center shadow-lg">
              <span class="text-white font-black text-lg">0<span class="text-[9px]">円</span></span>
            </div>
            <p class="text-white text-xs leading-tight font-bold">手数料すべて<br />0円</p>
          </div>
          <div>
            <div class="w-14 h-14 mx-auto mb-2 rounded-full bg-gradient-to-br from-terra to-amber flex items-center justify-center shadow-lg">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            </div>
            <p class="text-white text-xs leading-tight font-bold">最短即日<br />スピード対応</p>
          </div>
        </div>
      </div>

      <!-- CTA Buttons with glow -->
      <div class="flex flex-col sm:flex-row gap-3 mb-4">
        <a href="tel:052-990-3968" class="cta-glow bg-terra hover:bg-terra-light text-white font-black text-base md:text-lg px-8 py-4 rounded-xl text-center transition-colors">
          今すぐ電話 052-990-3968
        </a>
        <a href="https://lin.ee/j4wK9IM" target="_blank" rel="noopener noreferrer" class="cta-glow-line bg-line hover:brightness-110 text-white font-bold text-base md:text-lg px-8 py-4 rounded-xl text-center transition-all flex items-center justify-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .63.283.63.63 0 .344-.281.629-.63.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63h2.386c.346 0 .627.285.627.63 0 .349-.281.63-.63.63H17.61v1.125h1.755zm-3.855 3.016c0 .27-.174.51-.432.596-.064.021-.133.031-.199.031-.211 0-.391-.09-.51-.25l-2.443-3.317v2.94c0 .344-.279.629-.631.629-.346 0-.626-.285-.626-.629V8.108c0-.27.173-.51.43-.595.06-.023.136-.033.194-.033.195 0 .375.104.495.254l2.462 3.33V8.108c0-.345.282-.63.63-.63.345 0 .63.285.63.63v4.771zm-5.741 0c0 .344-.282.629-.631.629-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63.346 0 .628.285.628.63v4.771zm-2.466.629H4.917c-.345 0-.63-.285-.63-.629V8.108c0-.345.285-.63.63-.63.348 0 .63.285.63.63v4.141h1.756c.348 0 .629.283.629.63 0 .344-.282.629-.629.629M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.078 9.436-6.975C23.176 14.393 24 12.458 24 10.314"/></svg>
          LINEで写真査定
        </a>
      </div>
      <p class="text-white/35 text-xs">受付 9:00–21:00 年中無休 / 出張費・査定費 0円 / キャンセル無料</p>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════════ -->
<!--  信頼バー: カウントアップ                       -->
<!-- ═══════════════════════════════════════════════ -->
<section class="bg-bg-cream py-8 border-y border-border relative overflow-hidden" x-data x-init="
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        e.target.querySelectorAll('.count-up').forEach((el, i) => {
          setTimeout(() => el.classList.add('visible'), i * 150);
        });
        e.target.querySelectorAll('[data-count]').forEach(el => {
          const target = parseInt(el.dataset.count);
          let current = 0;
          const step = Math.ceil(target / 40);
          const timer = setInterval(() => {
            current += step;
            if (current >= target) { current = target; clearInterval(timer); }
            el.textContent = current.toLocaleString();
          }, 30);
        });
        observer.disconnect();
      }
    });
  }, { threshold: 0.5 });
  observer.observe($el);
">
  <!-- Decorative dots -->
  <div class="absolute inset-0 dots-pattern opacity-30 pointer-events-none"></div>
  <div class="relative max-w-4xl mx-auto px-5 flex flex-wrap justify-center gap-8 md:gap-20">
    <div class="text-center count-up">
      <p class="number-shimmer font-black text-3xl md:text-4xl"><span data-count="1200">0</span><span class="text-sm">件+</span></p>
      <p class="text-text-lighter text-xs mt-1">累計買取実績</p>
    </div>
    <div class="text-center count-up">
      <p class="number-shimmer font-black text-3xl md:text-4xl"><span data-count="98">0</span><span class="text-sm">%</span></p>
      <p class="text-text-lighter text-xs mt-1">お客様満足度</p>
    </div>
    <div class="text-center count-up">
      <p class="number-shimmer font-black text-3xl md:text-4xl">0<span class="text-sm">円</span></p>
      <p class="text-text-lighter text-xs mt-1">出張費・査定費</p>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════════ -->
<!--  お悩み                                        -->
<!-- ═══════════════════════════════════════════════ -->
<section class="py-16 md:py-24 bg-bg relative overflow-hidden">
  <div class="absolute top-0 right-0 w-64 h-64 bg-terra/5 rounded-full -translate-y-1/2 translate-x-1/2 blur-3xl"></div>
  <div class="max-w-4xl mx-auto px-5 relative">
    <div class="text-center mb-10 reveal reveal-up">
      <p class="text-terra text-xs font-bold tracking-widest uppercase mb-2">Troubles</p>
      <h2 class="text-xl md:text-3xl font-black text-text">こんなお悩みありませんか？</h2>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 stagger-children">
      {["引越し日が迫っているのに不用品が片付かない","冷蔵庫やタンスが重すぎて自分では運べない","処分にお金をかけたくない","今日中になんとかしたい","1点だけで頼むのは気が引ける","遺品整理を何から始めればいいかわからない"].map(p => (
        <div class="reveal reveal-up flex items-start gap-3 bg-white rounded-xl p-5 border border-border shadow-sm card-hover">
          <span class="bg-gradient-to-br from-terra to-amber text-white w-6 h-6 rounded-full flex items-center justify-center text-xs font-bold flex-shrink-0 mt-0.5 shadow">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
          </span>
          <p class="text-text text-sm leading-relaxed">{p}</p>
        </div>
      ))}
    </div>
    <div class="text-center mt-8 reveal reveal-up">
      <p class="inline-block bg-terra/10 text-terra font-bold text-sm px-6 py-2 rounded-full border border-terra/20">
        すべて徳丸商会が解決します
      </p>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════════ -->
<!--  サービス                                      -->
<!-- ═══════════════════════════════════════════════ -->
<section id="service" class="py-16 md:py-24 bg-white relative">
  <div class="absolute bottom-0 left-0 w-96 h-96 bg-amber/5 rounded-full translate-y-1/2 -translate-x-1/2 blur-3xl"></div>
  <div class="max-w-5xl mx-auto px-5 relative">
    <div class="text-center mb-12 reveal reveal-up">
      <p class="text-terra text-xs font-bold tracking-widest uppercase mb-2">Services</p>
      <h2 class="text-xl md:text-3xl font-black text-text mb-3">対応サービス</h2>
      <p class="text-text-light text-sm max-w-lg mx-auto">出張買取・不用品回収・遺品整理まで、まとめて対応します。</p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 stagger-children">
      {[
        { title: "出張買取", desc: "家電・家具・ブランド品を、ご自宅でその場で査定・現金買取。重い物の搬出もお任せください。", img: serviceCarry, gradient: "from-terra to-amber" },
        { title: "不用品回収", desc: "大量の不用品もトラック1台でまるっと回収。買取額で相殺して費用を抑えられます。", img: truckLoading, gradient: "from-red to-terra" },
        { title: "遺品整理", desc: "故人のお品物を丁寧に仕分け。供養の手配や処分もワンストップでお任せいただけます。", img: serviceEstate, gradient: "from-dark to-dark-warm" },
      ].map(s => (
        <div class="reveal reveal-scale bg-bg rounded-2xl overflow-hidden border border-border shadow-sm card-hover group">
          <div class="relative aspect-[4/3] overflow-hidden">
            <img src={s.img} alt={s.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
            <div class={`absolute inset-0 bg-gradient-to-t ${s.gradient} opacity-50`}></div>
            <div class="absolute bottom-0 inset-x-0 p-5">
              <h3 class="text-white font-black text-xl drop-shadow-lg">{s.title}</h3>
            </div>
          </div>
          <div class="p-5">
            <p class="text-text text-sm leading-relaxed">{s.desc}</p>
          </div>
        </div>
      ))}
    </div>
    <div class="mt-10 bg-gradient-to-r from-bg-cream to-bg-warm rounded-2xl p-6 border border-border max-w-2xl mx-auto reveal reveal-up">
      <p class="text-text text-sm leading-relaxed">
        <strong class="text-terra">出張買取とは</strong>、お客様のご自宅にスタッフが訪問し、お品物をその場で査定・買取するサービスです。出張費・見積もり・キャンセル料はすべて<strong class="text-terra">無料</strong>です。
      </p>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════════ -->
<!--  選ばれる理由                                   -->
<!-- ═══════════════════════════════════════════════ -->
<section class="py-16 md:py-24 bg-bg relative overflow-hidden">
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] bg-terra/3 rounded-full blur-3xl"></div>
  <div class="max-w-5xl mx-auto px-5 relative">
    <div class="text-center mb-12 reveal reveal-up">
      <p class="text-terra text-xs font-bold tracking-widest uppercase mb-2">Why Us</p>
      <h2 class="text-xl md:text-3xl font-black text-text">選ばれる理由</h2>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-5 stagger-children">
      {[
        { n: "01", t: "出張費・見積もり 完全無料", d: "査定だけでもOK。買取不成立でも費用は一切かかりません。", icon: "M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" },
        { n: "02", t: "最短30分で即日訪問", d: "お電話一本でスタッフが駆けつけます。急ぎのご依頼も対応。", icon: "M12 6v6l4 2 M22 12A10 10 0 1 1 12 2a10 10 0 0 1 10 10z" },
        { n: "03", t: "その場で現金払い", d: "査定額にご納得いただければ、すぐに現金をお渡しします。", icon: "M21 4H3M21 4v16H3V4M12 16V8M8 12h8" },
        { n: "04", t: "搬出もすべてお任せ", d: "重い冷蔵庫も大型タンスも、養生して傷なく運び出します。", icon: "M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z" },
      ].map(r => (
        <div class="reveal reveal-up flex gap-5 bg-white rounded-2xl p-6 border border-border shadow-sm card-hover">
          <div class="w-14 h-14 bg-gradient-to-br from-terra to-amber rounded-2xl flex items-center justify-center flex-shrink-0 shadow-lg">
            <span class="text-white font-black text-lg">{r.n}</span>
          </div>
          <div>
            <p class="text-text font-bold text-base mb-1">{r.t}</p>
            <p class="text-text-light text-sm leading-relaxed">{r.d}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════════ -->
<!--  ご依頼の流れ: ダーク背景 + 斜め区切り          -->
<!-- ═══════════════════════════════════════════════ -->
<section class="py-16 md:py-24 bg-dark text-white slant-top relative overflow-hidden" style="margin-top:40px;">
  <!-- Background image -->
  <img src={truckLoading} alt="" class="absolute inset-0 w-full h-full object-cover opacity-15" loading="lazy" aria-hidden="true" />
  <div class="absolute inset-0 bg-dark/80"></div>
  <!-- Decorative -->
  <div class="absolute top-0 right-0 w-72 h-72 bg-terra/10 rounded-full blur-3xl"></div>
  <div class="absolute bottom-0 left-0 w-56 h-56 bg-amber/10 rounded-full blur-3xl"></div>
  <div class="max-w-5xl mx-auto px-5 relative">
    <div class="text-center mb-12 reveal reveal-up">
      <p class="text-terra-light text-xs font-bold tracking-widest uppercase mb-2">Process</p>
      <h2 class="text-xl md:text-3xl font-black">ご依頼の流れ</h2>
