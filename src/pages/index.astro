  <!-- モバイル -->
  <div class="md:hidden relative min-h-[70svh] flex flex-col overflow-hidden">
    <img src={heroImg} alt="出張買取に向かう徳丸商会のスタッフ" class="absolute inset-0 w-full h-full object-cover object-[75%_40%]" loading="eager" fetchpriority="high" width="1200" height="800" />
    <div class="absolute inset-0 bg-gradient-to-b from-dark/90 from-0% via-dark/20 via-30% to-transparent"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-dark/90 from-0% via-dark/30 via-25% to-transparent"></div>

    <!-- 上部: キャンペーンバッジ + 主見出し + 説明 -->
