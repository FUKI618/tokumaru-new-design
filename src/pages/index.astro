}));
---

<Layout
  title="名古屋の家具家電出張買取・不用品回収なら徳丸商会｜出張費0円・最短30分"
  description="名古屋市・近郊エリアの家具家電出張買取・不用品回収なら徳丸商会。家電・家具・ブランド品・貴金属をその場で現金買取。遺品整理・家じまい・残置物撤去も一括対応。出張費・査定費0円、最短30分で即日訪問。古物商許可第541052601400号。052-990-3968"
  includeTopSchemas={true}
>

<!-- ═══ HEADER ═══ -->
<!-- 上部帯: 電話番号+営業時間 (PCのみ) -->
<div class="hidden md:block fixed top-0 inset-x-0 z-50 bg-dark border-b border-white/5">
  <div class="max-w-6xl mx-auto px-5 h-8 flex items-center justify-end gap-6 text-[11px] text-white/50">
    <span>受付 9:00–21:00（年中無休）</span>
    <a href="tel:052-990-3968" class="flex items-center gap-1 text-white/70 hover:text-white transition-colors">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
      052-990-3968
    </a>
  </div>
</div>
<!-- メインヘッダー -->
<header class="fixed top-0 md:top-8 inset-x-0 z-50 bg-dark/95 backdrop-blur-md shadow-2xl border-b border-terra/15"><div class="max-w-[1536px] @container mx-auto px-[2.3vw] md:px-[3.4cqw] h-[12.5vw] md:h-[6.8cqw] flex items-center justify-between">
