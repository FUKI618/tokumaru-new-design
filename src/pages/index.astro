        <svg xmlns="http://www.w3.org/2000/svg" class="w-[3.4vw] h-[3.4vw] md:w-[1.3cqw] md:h-[1.3cqw] flex-shrink-0" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg><span class="md:hidden">電話</span>
        <span class="hidden md:inline">電話で今すぐ査定</span>
      </a>
      <a href="https://lin.ee/j4wK9IM" target="_blank" rel="noopener noreferrer" class="flex items-center justify-center gap-[1vw] md:gap-[0.5cqw] bg-line hover:brightness-110 text-white font-bold text-[2.9vw] md:text-[1.05cqw] px-[2.9vw] md:px-[1.3cqw] py-[1.7vw] md:py-[0.78cqw] rounded-[1.6vw] md:rounded-[0.78cqw] transition-all shadow-md whitespace-nowrap">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-[3.4vw] h-[3.4vw] md:w-[1.3cqw] md:h-[1.3cqw] flex-shrink-0" viewbox="0 0 24 24" fill="currentColor"><path d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .63.283.63.63 0 .344-.281.629-.63.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63h2.386c.346 0 .627.285.627.63 0 .349-.281.63-.63.63H17.61v1.125h1.755zm-3.855 3.016c0 .27-.174.51-.432.596-.064.021-.133.031-.199.031-.211 0-.391-.09-.51-.25l-2.443-3.317v2.94c0 .344-.279.629-.631.629-.346 0-.626-.285-.626-.629V8.108c0-.27.173-.51.43-.595.06-.023.136-.033.194-.033.195 0 .375.104.495.254l2.462 3.33V8.108c0-.345.282-.63.63-.63.345 0 .63.285.63.63v4.771zm-5.741 0c0 .344-.282.629-.631.629-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63.346 0 .628.285.628.63v4.771zm-2.466.629H4.917c-.345 0-.63-.285-.63-.629V8.108c0-.345.285-.63.63-.63.348 0 .63.285.63.63v4.141h1.756c.348 0 .629.283.629.63 0 .344-.282.629-.629.629M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.078 9.436-6.975C23.176 14.393 24 12.458 24 10.314"/></svg><span class="md:hidden">LINE</span>
        <span class="hidden md:inline">LINEで無料査定</span>
      </a>
    </div>
  </div>
</header><main class="pt-[12.5vw] md:pt-[calc(32px+min(6.8vw,104px))]"><!-- ═══ HERO（comp-B_fv_v1 全デバイス共通・コンテナ比例 cqw） ═══ --><section class="bg-dark text-white"><!-- PC: comp-C_pc-fv_v4 中央集約型・比例再現（1536px基準→cqw） -->
