      <div class="flex gap-2.5 mb-2">
        <a href="tel:052-990-3968" class="cta-glow flex-1 bg-terra text-white font-black text-[13px] py-3 rounded-xl text-center shadow-lg whitespace-nowrap">電話で相談する</a>
        <a href="https://lin.ee/j4wK9IM" target="_blank" rel="noopener noreferrer" class="cta-glow-line flex-1 bg-line text-white font-bold text-[13px] py-3 rounded-xl text-center shadow-lg whitespace-nowrap">LINEで無料査定</a>
      </div>
    </div>
