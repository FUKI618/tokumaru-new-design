              </div>
              <h3 class="text-slate font-bold text-base mb-3">{step.title}</h3>
              <p class="text-text-light text-sm leading-[1.85]">{step.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section id="results" class="py-14 md:py-20">
      <div class="max-w-6xl mx-auto px-5">
        <div class="max-w-3xl mb-10">
          <p class="eyebrow mb-4">買取実績</p>
          <h2 class="font-display text-3xl md:text-5xl text-slate leading-[1.15] mb-4">
            名古屋での高額買取実績
          </h2>
          <p class="text-text-light text-sm md:text-base max-w-2xl">
            実際にご相談の多い品目を中心に、目安となる買取実績を掲載しています。年式・状態・メーカーにより変動しますが、価格感をつかむ参考としてご確認ください。
          </p>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-5">
          {results.map((result) => (
            <article class="rounded-[1.4rem] overflow-hidden border border-border bg-bg-white shadow-[0_16px_38px_rgba(19,33,42,0.06)] reveal-up">
              <div class="aspect-[4/3] bg-[linear-gradient(180deg,#fffdf9_0%,#f3ebdf_100%)] p-3">
                <img src={result.img} alt={result.alt} class="w-full h-full object-contain" loading="lazy" />
              </div>
              <div class="p-4">
                <p class="text-text-lighter text-xs mb-1">{result.detail}</p>
                <h3 class="text-slate font-bold text-sm md:text-base mb-2">{result.name}</h3>
                <p class="text-red font-black text-xl">
                  ¥{result.price}
                  <span class="text-text-lighter font-normal text-xs">〜</span>
                </p>
              </div>
            </article>
          ))}
        </div>

        <p class="text-text-lighter text-xs mt-5">
          ※掲載金額は一例です。品物の状態・年式・メーカー・付属品の有無により変動します。
        </p>
      </div>
    </section>

    <section class="py-14 md:py-20 bg-bg-white border-y border-border/70">
      <div class="max-w-6xl mx-auto px-5 grid lg:grid-cols-[minmax(0,1fr)_minmax(0,0.92fr)] gap-10 items-start">
        <div>
          <p class="eyebrow mb-4">回収実例</p>
          <h2 class="font-display text-3xl md:text-5xl text-slate leading-[1.15] mb-4">
            回収と片付けが入ると、
            <br />
            ここまで変わる
          </h2>
          <p class="text-text-light text-sm md:text-base mb-8 max-w-xl">
            引越し前や遺品整理では、買取だけでは解決しないケースが多くあります。徳丸商会では、価値がある物の査定と片付けを同時に進められます。
          </p>

          <div class="grid grid-cols-2 gap-4">
            <div>
              <div class="rounded-t-[1rem] bg-slate px-4 py-2 text-white text-xs font-bold tracking-[0.12em]">回収前</div>
              <img src={before} alt="不用品回収前の室内" class="w-full rounded-b-[1rem] object-cover shadow-[0_16px_38px_rgba(19,33,42,0.09)]" loading="lazy" />
            </div>
            <div>
              <div class="rounded-t-[1rem] bg-red px-4 py-2 text-white text-xs font-bold tracking-[0.12em]">回収後</div>
              <img src={after} alt="不用品回収後の室内" class="w-full rounded-b-[1rem] object-cover shadow-[0_16px_38px_rgba(19,33,42,0.09)]" loading="lazy" />
            </div>
          </div>
        </div>

        <div class="panel-soft rounded-[1.9rem] p-6 md:p-8">
          <p class="text-gold font-bold text-[11px] tracking-[0.14em] mb-4">お客様の声</p>
          {voices.map((voice) => (
            <article class="py-5 first:pt-0 last:pb-0 border-b last:border-b-0 border-border/80">
              <p class="text-teal font-bold text-xs mb-2">{voice.category}</p>
              <p class="text-text text-sm md:text-base leading-[1.9] mb-3">“{voice.text}”</p>
              <p class="text-text-lighter text-xs">{voice.who}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section id="company" class="py-14 md:py-20">
      <div class="max-w-6xl mx-auto px-5 grid lg:grid-cols-[minmax(0,0.92fr)_minmax(0,1.08fr)] gap-8">
        <div class="panel-dark rounded-[2rem] p-7 md:p-8">
          <p class="text-gold-light font-bold text-[11px] tracking-[0.14em] mb-4">会社情報</p>
          <h2 class="font-display text-3xl md:text-5xl text-white leading-[1.15] mb-5">
            名古屋市中区の
            <br />
            徳丸商会について
          </h2>
          <p class="text-white/68 text-sm md:text-base leading-[1.95] mb-7">
            出張買取を軸に、不用品回収、遺品整理、残置物撤去までご相談いただける地域密着の事業者です。価格だけでなく、片付け全体の進めやすさも重視しています。
          </p>
          <dl class="grid sm:grid-cols-2 gap-5 text-sm">
            <div>
              <dt class="text-white/45 mb-1">事業者名</dt>
              <dd class="font-bold text-white">{company.name}</dd>
            </div>
            <div>
              <dt class="text-white/45 mb-1">所在地</dt>
              <dd class="font-bold text-white">{company.locality}</dd>
            </div>
            <div>
              <dt class="text-white/45 mb-1">受付時間</dt>
              <dd class="font-bold text-white">{company.hours}</dd>
            </div>
            <div>
              <dt class="text-white/45 mb-1">古物商許可番号</dt>
              <dd class="font-bold text-white">{company.permitNumber}</dd>
            </div>
          </dl>
          <a
            href={company.sourceUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center mt-7 rounded-full bg-white text-slate font-bold text-sm px-6 py-3 hover:bg-gold-bg transition-colors"
          >
            掲載中の会社情報を見る
          </a>
        </div>

        <div id="area" class="rounded-[2rem] border border-border bg-bg-white p-7 md:p-8 shadow-[0_18px_48px_rgba(19,33,42,0.06)]">
          <p class="eyebrow mb-4">対応エリア</p>
          <h3 class="font-display text-3xl md:text-4xl text-slate leading-[1.2] mb-4">
            名古屋市全域と
            <br />
            近郊エリアに対応
          </h3>
          <p class="text-text-light text-sm md:text-base leading-[1.9] mb-7">
            名古屋市内を中心に、近郊の愛知県エリアや一部三重県エリアまで対応しています。市外案件もまずはご相談ください。
          </p>

          <div class="mb-6">
            <p class="text-teal font-bold text-sm mb-3">名古屋市16区</p>
            <div class="flex flex-wrap gap-2">
              {wards.map((ward) => (
                <span class="rounded-full bg-gold-bg text-text text-xs px-3 py-1.5">{ward}</span>
              ))}
            </div>
          </div>

          <div>
            <p class="text-teal font-bold text-sm mb-3">近郊エリア</p>
            <div class="flex flex-wrap gap-2">
              {nearbyAreas.map((area) => (
                <span class="rounded-full bg-bg text-text text-xs px-3 py-1.5 border border-border">{area}</span>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <section id="faq" class="py-14 md:py-20 bg-bg-white border-y border-border/70">
      <div class="max-w-4xl mx-auto px-5">
        <div class="max-w-3xl mb-10">
          <p class="eyebrow mb-4">よくあるご質問</p>
          <h2 class="font-display text-3xl md:text-5xl text-slate leading-[1.15] mb-4">
            名古屋の出張買取で
            <br />
            よくあるご質問
          </h2>
          <p class="text-text-light text-sm md:text-base">
            電話前に確認されやすい内容を中心にまとめています。料金、スピード、対応範囲など、判断に必要な点を先に確認できます。
          </p>
        </div>

        <div class="space-y-3">
          {faqs.map((faq, index) => (
            <div x-data={`{ open: ${index === 0 ? "true" : "false"} }`} class="rounded-[1.3rem] border border-border bg-bg overflow-hidden shadow-[0_12px_32px_rgba(19,33,42,0.04)]">
              <button
                x-on:click="open = !open"
                class="w-full flex items-start justify-between gap-4 p-5 md:p-6 text-left"
                x-bind:aria-expanded="open.toString()"
              >
                <div class="flex items-start gap-4">
                  <span class="w-8 h-8 rounded-full bg-slate text-white text-xs font-bold flex items-center justify-center flex-shrink-0 mt-0.5">Q</span>
                  <span class="text-text font-bold text-sm md:text-base leading-[1.8]">{faq.question}</span>
                </div>
                <span class="text-gold text-xl leading-none flex-shrink-0 transition-transform duration-200" x-bind:class="open && 'rotate-45'">+</span>
              </button>
              <div x-show="open" x-transition class="px-5 md:px-6 pb-5 md:pb-6" style="display: none;">
                <div class="pl-0 md:pl-12 flex items-start gap-4">
                  <span class="w-8 h-8 rounded-full bg-red text-white text-xs font-bold flex items-center justify-center flex-shrink-0">A</span>
                  <p class="text-text-light text-sm md:text-base leading-[1.9]">{faq.answer}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section id="contact" class="py-16 md:py-24 bg-slate text-white">
      <div class="max-w-4xl mx-auto px-5 text-center">
        <p class="eyebrow justify-center mb-4">お問い合わせ</p>
        <h2 class="font-display text-3xl md:text-5xl leading-[1.15] mb-4">
          まずはお気軽に
          <br />
          ご相談ください
        </h2>
        <p class="text-white/68 text-sm md:text-base max-w-2xl mx-auto leading-[1.95] mb-8">
          名古屋で出張買取、不用品回収、遺品整理を頼みたいけれど、何から始めればいいか分からない。
          そんな段階でも問題ありません。電話かLINEで状況を伺い、進め方を整理します。
        </p>

        <div class="flex flex-col sm:flex-row justify-center gap-3 mb-5">
          <a
            href={`tel:${company.phone}`}
            class="inline-flex items-center justify-center rounded-2xl bg-red hover:bg-red-light text-white font-black text-lg px-8 py-4 transition-colors shadow-[0_20px_50px_rgba(188,75,53,0.28)]"
          >
            {company.phone}
          </a>
          <a
            href={company.lineUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center rounded-2xl bg-line hover:brightness-110 text-white font-bold text-lg px-8 py-4 transition-all shadow-[0_18px_40px_rgba(6,199,85,0.24)]"
          >
            LINEで無料査定
          </a>
        </div>

        <p class="text-white/38 text-xs">
          受付 {company.hours} / 所在地 {company.locality} / プライバシーポリシーは
          <a href={privacyPolicyPath} class="underline underline-offset-4 hover:text-white transition-colors">こちら</a>
        </p>
      </div>
    </section>
  </main>

  <footer class="bg-slate-dark text-white/40 py-12">
    <div class="max-w-6xl mx-auto px-5 grid md:grid-cols-[minmax(0,1fr)_auto_auto] gap-8 items-start">
      <div>
        <div class="flex items-center gap-3 mb-3">
          <img src={logo} alt="徳丸商会" width="28" height="28" class="w-7 h-7" />
          <div>
            <p class="text-white font-bold text-sm">徳丸商会</p>
            <p class="text-white/38 text-[10px] tracking-[0.12em] mt-1">名古屋の出張買取・不用品回収</p>
          </div>
        </div>
        <p class="text-xs leading-[1.9] max-w-sm">
          名古屋市中区を拠点に、出張買取、不用品回収、遺品整理、残置物撤去まで対応しています。
        </p>
      </div>

      <div class="text-xs">
        <p class="text-white/55 font-bold mb-3">お問い合わせ</p>
        <a href={`tel:${company.phone}`} class="block hover:text-white transition-colors mb-1">{company.phone}</a>
        <p>{company.hours}</p>
        <p>{company.permitNumber}</p>
      </div>

      <div class="text-xs">
        <p class="text-white/55 font-bold mb-3">メニュー</p>
        <nav class="flex flex-col gap-1.5">
          <a href={sectionPath("answers")} class="hover:text-white transition-colors">早わかり</a>
          <a href={sectionPath("service")} class="hover:text-white transition-colors">サービス</a>
          <a href={sectionPath("results")} class="hover:text-white transition-colors">買取実績</a>
          <a href={sectionPath("company")} class="hover:text-white transition-colors">会社情報</a>
          <a href={sectionPath("faq")} class="hover:text-white transition-colors">よくある質問</a>
          <a href={privacyPolicyPath} class="hover:text-white transition-colors">プライバシーポリシー</a>
        </nav>
      </div>
    </div>

    <div class="max-w-6xl mx-auto px-5 mt-8 pt-6 border-t border-white/8 pb-16 md:pb-0 text-center text-xs text-white/15">
      &copy; {new Date().getFullYear()} 徳丸商会
    </div>
  </footer>

  <div
    x-data="{ show: false }"
    x-init="window.addEventListener('scroll', () => { show = window.scrollY > 460 })"
    x-show="show"
    x-transition:enter="transition ease-out duration-300"
    x-transition:enter-start="translate-y-full"
    x-transition:enter-end="translate-y-0"
    x-transition:leave="transition ease-in duration-200"
    x-transition:leave-start="translate-y-0"
    x-transition:leave-end="translate-y-full"
    class="fixed bottom-0 inset-x-0 z-50 md:hidden border-t border-white/10 bg-slate/94 backdrop-blur-xl"
    style="display: none;"
  >
    <div class="flex gap-2 px-4 py-3">
      <a href={`tel:${company.phone}`} class="flex-1 rounded-xl bg-red text-white font-bold py-3 text-xs text-center shadow">電話で相談</a>
      <a href={company.lineUrl} target="_blank" rel="noopener noreferrer" class="flex-1 rounded-xl bg-line text-white font-bold py-3 text-xs text-center shadow">LINE査定</a>
    </div>
  </div>

  <script>window.addEventListener('load',()=>{setTimeout(()=>document.documentElement.classList.add('scroll-ready'),250)});</script>
</Layout>
